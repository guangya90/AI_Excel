# 勿提交真实密码。复制为 `.env` 后替换 USER / PASSWORD / 主机名。

# --- Neon（推荐）---
# 控制台「Connection string」：Pooled → 填到 DATABASE_URL；Unpooled → 填到 DIRECT_URL
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-PROJECT-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-PROJECT.REGION.aws.neon.tech/neondb?sslmode=require"

# Vercel 集成 Neon 时若只有 POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING：
#   DATABASE_URL  ← 池化那条（如 POSTGRES_PRISMA_URL 或带 -pooler 的 URL）
#   DIRECT_URL    ← 非池化那条（如 POSTGRES_URL_NON_POOLING）

# --- Supabase ---
# DATABASE_URL="postgresql://postgres.xxx:[PASSWORD]@xxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.xxx:[PASSWORD]@xxx.pooler.supabase.com:5432/postgres"
