generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /// 应用运行时：Neon 用 `-pooler` 池化串；Supabase 用 `6543` + `pgbouncer=true`
  url       = env("DATABASE_URL")
  /// migrate / db push：Neon 用非池化主机；Supabase 用 `5432` 直连串
  directUrl = env("DIRECT_URL")
}

/// 订单头表（外部编码/收货门店/收件人信息，A组B组二选一）
model OrderHeader {
  id              String        @id @default(cuid())
  batchId         String        @map("batch_id")
  externalCode    String?       @map("external_code")
  receiverStore   String?       @map("receiver_store")
  receiverName    String?       @map("receiver_name")
  receiverPhone   String?       @map("receiver_phone")
  receiverAddress String?       @map("receiver_address")
  remark          String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  details         OrderDetail[]

  @@index([externalCode])
  @@index([batchId])
  @@index([createdAt])
  @@map("order_headers")
}

/// 订单明细表（SKU编码/名称/数量/规格）
model OrderDetail {
  id        String      @id @default(cuid())
  headerId  String      @map("header_id")
  header    OrderHeader @relation(fields: [headerId], references: [id], onDelete: Cascade)
  skuCode   String?     @map("sku_code")
  skuName   String?     @map("sku_name")
  skuQty    Int?        @map("sku_qty")
  skuSpec   String?     @map("sku_spec")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([headerId])
  @@map("order_details")
}

/// 应用设置（Key-Value存储，如API Key等）
model AppSetting {
  key        String   @id
  value      String   @db.Text
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

/// 通用解析规则配置（替代旧 TemplateMapping 的硬编码方式）
model ParseRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  /// 适用格式：xlsx / xls / docx / pdf
  fileFormat  String
  /// 完整 ParseRuleConfig JSON（区域/列映射/变换/尾部/默认值/AI元数据）
  config      Json
  /// 规则签名（sha256，用于去重）
  signature   String?  @unique
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt  @map("updated_at")

  @@map("parse_rules")
}
